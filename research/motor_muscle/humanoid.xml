<mujoco model="dense_motor_humanoid">
  <compiler angle="radian" autolimits="true"/>
  <option timestep="0.001" integrator="implicitfast" solver="Newton"
          iterations="8" ls_iterations="12" tolerance="1e-8"
          gravity="0 0 -9.81"/>
  <visual>
    <global offwidth="960" offheight="720"/>
  </visual>
  <default>
    <joint damping="2.2" stiffness="20" armature="0.015" limited="true"/>
    <geom condim="4" friction="0.9 0.02 0.001" contype="1" conaffinity="0"
          solref="0.006 1" solimp="0.95 0.99 0.002" density="800"/>
  </default>
  <asset>
    <material name="body" rgba="0.35 0.55 0.75 1"/>
    <material name="foot" rgba="0.18 0.22 0.28 1"/>
    <material name="ground" rgba="0.82 0.84 0.87 1"/>
  </asset>
  <worldbody>
    <light pos="0 -3 4" dir="0 1 -1"/>
    <geom name="floor" type="plane" size="4 4 0.1" material="ground"
          condim="4" friction="1.0 0.03 0.002" contype="0" conaffinity="1"/>
    <body name="pelvis" pos="0 0 0.95">
      <freejoint name="root"/>
      <geom type="box" size="0.14 0.105 0.09" mass="8.0" material="body"/>

      <body name="torso_roll_link" pos="0 0 0.08">
        <inertial pos="0 0 0" mass="0.10" diaginertia="0.001 0.001 0.001"/>
        <joint name="spine_roll" axis="1 0 0" range="-0.35 0.35"/>
        <body name="torso" pos="0 0 0.23">
          <joint name="spine_pitch" axis="0 1 0" range="-0.45 0.45"/>
          <geom type="box" size="0.17 0.105 0.23" mass="18.0" material="body"/>
          <body name="head" pos="0 0 0.34">
            <geom type="sphere" size="0.105" mass="4.5" material="body"/>
          </body>
          <body name="left_upper_arm" pos="0 0.20 0.16">
            <joint name="left_shoulder" axis="0 1 0" range="-1.2 1.2"/>
            <geom type="capsule" fromto="0 0 0 0 0 -0.27" size="0.045" mass="2.0" material="body"/>
            <body name="left_forearm" pos="0 0 -0.27">
              <joint name="left_elbow" axis="0 1 0" range="-0.1 1.7"/>
              <geom type="capsule" fromto="0 0 0 0 0 -0.25" size="0.038" mass="1.3" material="body"/>
            </body>
          </body>
          <body name="right_upper_arm" pos="0 -0.20 0.16">
            <joint name="right_shoulder" axis="0 1 0" range="-1.2 1.2"/>
            <geom type="capsule" fromto="0 0 0 0 0 -0.27" size="0.045" mass="2.0" material="body"/>
            <body name="right_forearm" pos="0 0 -0.27">
              <joint name="right_elbow" axis="0 1 0" range="-0.1 1.7"/>
              <geom type="capsule" fromto="0 0 0 0 0 -0.25" size="0.038" mass="1.3" material="body"/>
            </body>
          </body>
        </body>
      </body>

      <body name="left_hip_roll_link" pos="0 0.095 -0.06">
        <inertial pos="0 0 0" mass="0.10" diaginertia="0.001 0.001 0.001"/>
        <joint name="left_hip_roll" axis="1 0 0" range="-0.45 0.45" stiffness="45"/>
        <body name="left_thigh">
          <joint name="left_hip_pitch" axis="0 1 0" range="-1.0 1.0" stiffness="45"/>
          <geom type="capsule" fromto="0 0 0 0 0 -0.42" size="0.065" mass="6.5" material="body"/>
          <body name="left_shin" pos="0 0 -0.42">
            <joint name="left_knee" axis="0 1 0" range="-0.05 1.6" stiffness="55"/>
            <geom type="capsule" fromto="0 0 0 0 0 -0.40" size="0.052" mass="4.0" material="body"/>
            <body name="left_ankle_roll_link" pos="0 0 -0.40">
              <inertial pos="0 0 0" mass="0.10" diaginertia="0.001 0.001 0.001"/>
              <joint name="left_ankle_roll" axis="1 0 0" range="-0.35 0.35" stiffness="75"/>
              <body name="left_foot">
                <joint name="left_ankle_pitch" axis="0 1 0" range="-0.55 0.55" stiffness="75"/>
                <geom name="left_foot_geom" type="box" pos="0.07 0 -0.035"
                      size="0.19 0.095 0.035" mass="1.8" material="foot"/>
              </body>
            </body>
          </body>
        </body>
      </body>

      <body name="right_hip_roll_link" pos="0 -0.095 -0.06">
        <inertial pos="0 0 0" mass="0.10" diaginertia="0.001 0.001 0.001"/>
        <joint name="right_hip_roll" axis="1 0 0" range="-0.45 0.45" stiffness="45"/>
        <body name="right_thigh">
          <joint name="right_hip_pitch" axis="0 1 0" range="-1.0 1.0" stiffness="45"/>
          <geom type="capsule" fromto="0 0 0 0 0 -0.42" size="0.065" mass="6.5" material="body"/>
          <body name="right_shin" pos="0 0 -0.42">
            <joint name="right_knee" axis="0 1 0" range="-0.05 1.6" stiffness="55"/>
            <geom type="capsule" fromto="0 0 0 0 0 -0.40" size="0.052" mass="4.0" material="body"/>
            <body name="right_ankle_roll_link" pos="0 0 -0.40">
              <inertial pos="0 0 0" mass="0.10" diaginertia="0.001 0.001 0.001"/>
              <joint name="right_ankle_roll" axis="1 0 0" range="-0.35 0.35" stiffness="75"/>
              <body name="right_foot">
                <joint name="right_ankle_pitch" axis="0 1 0" range="-0.55 0.55" stiffness="75"/>
                <geom name="right_foot_geom" type="box" pos="0.07 0 -0.035"
                      size="0.19 0.095 0.035" mass="1.8" material="foot"/>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>
  <sensor>
    <framequat name="pelvis_quat" objtype="body" objname="pelvis"/>
    <frameangvel name="pelvis_angvel" objtype="body" objname="pelvis"/>
    <subtreecom name="center_of_mass" body="pelvis"/>
  </sensor>
</mujoco>
